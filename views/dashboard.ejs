<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="nav">
  <div class="nav-title">Threadly</div>
  <div>
    <button onclick="toggleDarkMode()">🌙</button> |
    <a href="/dashboard">Dashboard</a> |
    <a href="/topics">Topics</a> |
    <a href="/stats/topics">Stats</a> |
    <a href="/login">Logout</a>
  </div>
</div>

<div class="container">

  <h1>Welcome, <%= user.username %></h1>

  <h2>Your Subscribed Topics</h2>

  <% if (topics.length === 0) { %>
    <p>You are not subscribed to any topics yet.</p>
  <% } %>

  <% topics.forEach(topic => { %>
    <div class="card topic-card">

      <h3><%= topic.title %></h3>

      <!-- Recent Messages -->
      <h4>Recent Messages:</h4>
      <% if (topicMessages[topic._id].recent.length === 0) { %>
        <p>No messages yet.</p>
      <% } else { %>
        <% topicMessages[topic._id].recent.forEach(msg => { %>
          <div class="message">
            <strong><%= msg.author.username %>:</strong>
            <p><%= msg.content %></p>
          </div>
        <% }) %>
      <% } %>

      <!-- Full Chat History (scrollable) -->
      <h4>Chat History:</h4>
      <div class="chat-history">
        <% topicMessages[topic._id].all.forEach(msg => { %>
          <div class="chat-message">
            <strong><%= msg.author.username %>:</strong>
            <span><%= msg.content %></span>
          </div>
        <% }) %>
      </div>

      <!-- Unsubscribe -->
      <form action="/topics/<%= topic._id %>/unsubscribe" method="POST">
        <button type="submit" class="danger">Unsubscribe</button>
      </form>

      <!-- Post Message -->
      <form action="/topics/<%= topic._id %>/messages" method="POST" class="message-form">
        <input type="text" name="content" placeholder="Write a message..." required>
        <button type="submit" class="primary">Post</button>
      </form>

    </div>
  <% }) %>

  <a href="/topics">View all topics</a>

</div>

<script src="/theme.js"></script>
</body>
</html>
