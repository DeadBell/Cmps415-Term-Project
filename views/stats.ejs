<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Stats</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<header class="nav">
    <h1>Message Board Stats</h1>
    <div class="top-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/topics">All Topics</a>
        <a href="/logout">Logout</a>
    </div>
</header>

<main class="container">

    <section class="card">
        <h2>Topic Statistics</h2>

        <p><strong>Total Topics:</strong> <%= totalTopics %></p>
        <p><strong>Total Posts:</strong> <%= totalPosts %></p>
        <p><strong>Total Subscriptions:</strong> <%= totalSubscriptions %></p>
    </section>

    <section class="card">
        <h2>Topics Breakdown</h2>

        <% if (topics.length === 0) { %>
            <p>No topics found.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Topic</th>
                        <th>Posts</th>
                        <th>Subscribers</th>
                    </tr>
                </thead>
                <tbody>
                    <% topics.forEach(topic => { %>
                        <tr>
                            <td><%= topic.title %></td>
                            <td><%= topic.postCount || 0 %></td>
                            <td><%= topic.subscriberCount || 0 %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

</main>

</body>
</html>
